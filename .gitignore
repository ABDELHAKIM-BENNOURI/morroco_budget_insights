# Python
__pycache__/
*.pyc
*.pyo
.env
*.egg-info/

# Data sensible (contenu ignoré, structure trackée via .gitkeep)
# Exception : data/clean/*.csv est tracké (texte, ~80 KB, source du pipeline
# en CI pour le job deploy-pages — sans ces CSV, pas de figures à déployer).
data/raw/*
data/clean/*
!data/clean/*.csv
data/models/*
!data/*/.gitkeep

# Node
node_modules/
dashboard/node_modules/

# Build
dashboard/dist/

# Données figures copiées au runtime par dashboard/scripts/copy-data.mjs
dashboard/public/data/

# OS
.DS_Store
Thumbs.db.env

